:: functions {"position":"200,725","size":"100,100"}
<<set setup.equip = function equip(slot, item) {
    let adj;
    if (slot !== "weapon" && slot !== "armor" && slot !== "shield") {
        throw new Error(`Invalid gear slot: ${slot}`);
    }
    if (item === "") {
        adj = clone({ attack: 0, defense: 0, agility: 0, tag: "", isRanged: false });
    } else {
        adj = setup[slot].get(item);
    }
    if (!adj) {
        throw new Error(`Invalid ${slot}: ${item}`);
    }
    if (slot === "weapon") {
        $weaponSlot = item;
        $player.tag = adj.tag || ""; // Update player tag
        $player.isRanged = adj.isRanged || false; // Update player isRanged
    } else if (slot === "armor") {
        $armorSlot = item;
    } else if (slot === "shield") {
        $shieldSlot = item;
        }
    $adjustments[slot] = clone(adj);
}>>

<<set setup.getStat = function getStat (stat) {
    if (ndef $player[stat]) {
        throw new Error(`Invalid stat: ${stat}`);
    }
    let ret = Math.trunc(Math.clamp($player[stat] + $adjustments.weapon[stat] + $adjustments.armor[stat], 1, 99));
    if (Number.isNaN(ret)) {
        ret = 1;
    }
    return ret;
}>>


